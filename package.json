{
  "name": "livre",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared",
    "fe-libs/*"
  ],
  "scripts": {
    "dev": "concurrently -n types,client,server,proto -c blue,cyan,yellow,magenta \"npm run dev -w @livre/types\" \"npm run dev -w client\" \"npm run dev -w server\" \"npx serve prototypes -p 5174 -n\"",
    "build": "npm run build -w @livre/types && npm run build -w client",
    "start": "npm run start -w server",
    "install:all": "npm install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4"
  }
}
